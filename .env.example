# reins 환경변수 예시. 복사해서 .env(또는 .env.local)로 사용.
#   cp .env.example .env
# 서버(server/app/config.py)가 읽음 — 로드 순서: .env.local > .env
# 비어있는 값(특히 토큰/비밀번호)은 반드시 실제 값으로 채울 것.

# === PostgreSQL ===
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=reins
DB_USER=reins
DB_PASSWORD=changeme

# === API 서버 ===
PORT=21001
LOG_LEVEL=info
# API 인증 토큰. 비워두면 인증 생략(로컬 개발 편의). 운영은 반드시 설정.
REINS_API_TOKEN=
# CORS 허용 오리진(콤마 구분)
CORS_ORIGINS=http://localhost:21002,http://localhost:3000

# === Telegram (outbound 알림 only) ===
# 미설정 시 알림 스킵. 포럼 그룹 chat_id 사용 권장.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# topic 자동생성 폭증 가드. 미설정 시 자동생성 없음.
TELEGRAM_DEFAULT_CHAT_ID=

# === Watchdog (heartbeat 정체 감지) ===
# 0 = off
WATCHDOG_INTERVAL_SEC=300
# 무업데이트 지속 시 이 값(초)을 넘기면 stalled 판정
WATCHDOG_STALE_SEC=1800

# === 아침 다이제스트 (KST) ===
# 0 = off
DIGEST_CRON_HOUR=8
